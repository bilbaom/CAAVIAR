// nextflow.config
// Execution profiles and per-process resource settings.
// All experiment-specific parameters (paths, minimap params, amplicon, etc.)
// live in the mhaav25_config_*.sh file, not here.
//
// Run with:  nextflow run main.nf -profile slurm  (HPC)
//            nextflow run main.nf -profile local   (laptop/workstation)

conda.enabled = true

params.blast_db = "${projectDir}/assets/blast_db/blastdb"

profiles {

    local {
        process.executor = 'local'
        process.cpus     = 4
        process.memory   = '16 GB'
    }

    slurm {
        process.executor   = 'slurm'
        process.queue      = 'short'         // -p short  (override per process below)
        process.clusterOptions = ''
        // Global SLURM defaults — overridden per-process in the withName blocks below
        process.cpus       = 4
        process.memory     = '8 GB'
        process.time       = '10h'
    }
}

// ---------------------------------------------------------------
// Per-process resource tuning
// These apply regardless of profile (local just ignores the SLURM
// directives; values are still used to set cpus/memory).
// ---------------------------------------------------------------
process {

    withName: 'TRIM_READS' {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
		conda = 'bioconda::bbmap=39.01'
    }

    withName: 'MERGE_READS' {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
		conda = 'bioconda::flash=1.2.11'
    }

    withName: 'FILTER_AMPLICONS' {
        cpus   = 2
        memory = '4 GB'
        time   = '1h'
		conda = 'bioconda::seqkit=2.10'
    }
	
	withName: 'INDEX_GENOME' {
        cpus   = 4
        memory = '16 GB'
        time   = '4h'
        conda  = 'bioconda::minimap2=2.28'
    }

    withName: 'MAP_READS' {
        cpus   = 4
        memory = '16 GB'
        time   = '4h'
		conda = 'bioconda::minimap2=2.28 bioconda::samtools=1.21'
    }
	
	withName: 'FILTER_MAPPINGS' {
        conda = 'bioconda::samtools=1.21'
		memory = '16 GB'
        time   = '4h'
    }

    withName: 'BLAST_AAV' {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
		conda = 'bioconda::blast=2.17 bioconda::seqkit=2.10'
    }

    withName: 'STEP1_CALL_INDELS' {
        cpus   = 2
        memory = '32 GB'   // R can be memory-hungry with many samples
        time   = '6h'
		conda = 'conda-forge::r-base conda-forge::r-stringr bioconda::bioconductor-crisprvariants bioconda::bioconductor-rtracklayer'
    }

    withName: 'STEP2_INSERTIONS' {
        cpus   = 4
        memory = '8 GB'
        time   = '2h'
		conda = 'conda-forge::r-base=4.4 conda-forge::r-reshape2=1.4.4 conda-forge::r-seqinr=4.2_36 bioconda::blast=2.17'
    }

    withName: 'STEP3_MH' {
        cpus   = 1
        memory = '4 GB'
        time   = '1h'
		conda = 'conda-forge::python>=3.10 conda-forge::pandas=2.3.2 conda-forge::numpy=2.3.2'
    }

    withName: 'GATHER_RESULTS' {
        cpus   = 1
        memory = '4 GB'
        time   = '1h'
		conda = 'conda-forge::python>=3.10 conda-forge::pandas=2.3.2'
    }
}


// ---------------------------------------------------------------
// Output and work directories
// ---------------------------------------------------------------
workDir   = 'work'          // Nextflow scratch space (can be on scratch partition)
